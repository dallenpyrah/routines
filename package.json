{
  "name": "routines",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Effect-native local routines scheduler using Effect Cluster.",
  "packageManager": "bun@1.3.14",
  "bin": {
    "routines": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "daemon": "tsx src/cli.ts daemon",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src",
    "format": "prettier --check .",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@effect/cluster": "^0.59.0",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.107.0",
    "@effect/rpc": "^0.75.1",
    "@effect/sql": "^0.51.1",
    "@effect/sql-sqlite-node": "^0.52.0",
    "@effect/workflow": "^0.18.2",
    "effect": "^3.21.4",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
